FROM python:3.12-slim

WORKDIR /app

# Install poppler-utils for pdftotext (payroll PDF parsing)
RUN apt-get update && apt-get install -y --no-install-recommends poppler-utils && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir fastapi uvicorn[standard] sqlalchemy[asyncio] asyncpg \
    alembic pydantic pydantic-settings python-jose[cryptography] passlib[bcrypt] \
    redis celery httpx python-multipart itsdangerous email-validator resend \
    langgraph langchain-core langchain-anthropic openai reportlab PyJWT \
    boto3 python-docx

COPY api/ ./api/
COPY monitoring/ ./monitoring/
COPY pyproject.toml ./

ENV PORT=8000
EXPOSE ${PORT}

CMD uvicorn api.main:app --host 0.0.0.0 --port ${PORT}
