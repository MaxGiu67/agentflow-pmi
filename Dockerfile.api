FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn[standard] sqlalchemy[asyncio] asyncpg \
    alembic pydantic pydantic-settings python-jose[cryptography] passlib[bcrypt] \
    redis celery httpx python-multipart itsdangerous email-validator

COPY api/ ./api/
COPY pyproject.toml ./

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
