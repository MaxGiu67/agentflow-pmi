# Database
DATABASE_URL=postgresql+asyncpg://contabot:contabot@localhost:5432/contabot
DATABASE_URL_SYNC=postgresql://contabot:contabot@localhost:5432/contabot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=AgentFlow PMI
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Encryption (per tenant_settings AES-256)
AES_KEY=change-me-32-bytes-hex-encoded-key

# ── Servizi attivi ──────────────────────

# A-Cube — unico provider: fatturazione SDI + Open Banking PSD2
ACUBE_API_KEY=change-me
ACUBE_BASE_URL=https://api.acubeapi.com

# Brevo — email marketing + tracking
BREVO_API_KEY=change-me
BREVO_SENDER_EMAIL=commerciale@nexadata.it
BREVO_SENDER_NAME=Nexa Data

# OpenAI — chatbot + PDF extraction
OPENAI_API_KEY=change-me

# Microsoft 365 Calendar — OAuth2 push to Outlook
MICROSOFT_CLIENT_ID=change-me
MICROSOFT_CLIENT_SECRET=change-me
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://yourdomain.com/api/v1/calendar/microsoft/callback

# ── Servizi disabilitati ────────────────
# Salt Edge: rimosso — A-Cube gestisce Open Banking
# FiscoAPI: rimosso — A-Cube gestisce cassetto fiscale via SDI
# Odoo CRM: opzionale — CRM interno (ADR-009), Odoo solo per bundle clienti

# SMTP (per email di sistema: verifica email, password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@agentflow.it
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@agentflow.it
