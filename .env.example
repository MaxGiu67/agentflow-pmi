# Database
DATABASE_URL=postgresql+asyncpg://contabot:contabot@localhost:5432/contabot
DATABASE_URL_SYNC=postgresql://contabot:contabot@localhost:5432/contabot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@contabot.it
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@contabot.it

# App
APP_NAME=ContaBot
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Encryption
AES_KEY=change-me-32-bytes-hex-encoded-key
